# ─────────────────────────────────────────────
# SafeHer – Frontend .env Template
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Commit THIS file. NEVER commit the real .env.

# ── Supabase ─────────────────────────────────
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_URL=https://your_supabase_project_id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Twilio (client-side safe values only) ────
# NEVER put TWILIO_AUTH_TOKEN here – use Supabase Edge Function secrets.
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid
VITE_TWILIO_DEFAULT_COUNTRY_CODE=91

# ── Google Places ─────────────────────────────
# The API key is used server-side in a Supabase Edge Function.
# Add it to: Supabase → Settings → Edge Functions → Secrets
# VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── App ───────────────────────────────────────
VITE_APP_NAME=SafeHer
VITE_APP_ENV=development
